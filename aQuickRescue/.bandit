# Bandit Configuration - Security Linting for QuickRescue
# https://bandit.readthedocs.io/

[bandit]
tests = [B201, B301, B302, B303, B304, B305, B306, B307, B308, B309, B310, B311, B312, B313, B314, B315, B316, B317, B318, B319, B320, B321, B322, B323, B324, B325]
exclude_dirs = [tests, venv, migrations, .venv]
skips = []

[bandit_exclude_dirs]
exclude_dirs = tests,venv,migrations,.venv,build,dist

# Ignore specific test patterns
[bandit_test_skip]
skip_tests = [
  B101,  # assert_used
]
