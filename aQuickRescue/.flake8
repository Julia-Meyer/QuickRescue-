[flake8]
# Flake8 Configuration - Speckit Compliance
# Code Quality Standards for QuickRescue

max-line-length = 100
extend-ignore = E203, E266, E501, W503
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    build,
    dist,
    .eggs,
    *.egg-info,
    .pytest_cache,
    .mypy_cache,
    migrations,
    node_modules
per-file-ignores =
    __init__.py: F401
    tests/*: F811, F401

# Complexity
max-complexity = 10

# Docstring convention
docstring-convention = google

# Count
statistics = True

